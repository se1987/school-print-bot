# === LINE Messaging API ===
LINE_CHANNEL_SECRET=your_channel_secret_here
LINE_CHANNEL_ACCESS_TOKEN=your_channel_access_token_here

# === Gemini API ===
GEMINI_API_KEY=your_gemini_api_key_here

# === Google Calendar API ===
# scripts/authorize_google.py を実行して取得したJSONを設定
# 未設定の場合はカレンダー連携がスキップされる（他の機能は正常動作）
GOOGLE_CALENDAR_CREDENTIALS_JSON=
# 登録先カレンダーID（省略時はプライマリカレンダー）
GOOGLE_CALENDAR_ID=primary

# === アプリ設定 ===
PORT=8000
# DB保存先（Docker使用時は /app/data/school_prints.db を推奨）
DB_PATH=school_prints.db
